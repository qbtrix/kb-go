    "task-management-api-express-route-handlers-and-controller": {
      "summary": "This module defines the API layer for a task management system using Express.js, including a TaskController class that handles CRUD operations and supporting interfaces for repository abstraction. It provides route handlers for listing, retrieving, creating, updating, and deleting tasks, along with middleware for health checks and centralized error handling.",
      "title": "Task Management API - Express Route Handlers and Controller"
    },
    "task-system-domain-types-and-interfaces": {
      "summary": "Comprehensive TypeScript type definitions for a task management system, including domain entities (Task, User, Team), input interfaces for mutations, and enums for status, priority, and user role management. Defines the core data structures and contracts for task operations, filtering, and sorting functionality.",
      "title": "Task System Domain Types and Interfaces"
    }
  },
